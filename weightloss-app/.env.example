# =============================================================================
# Weight Loss Web App - environment variables
# Set these as environment variables in Portainer when deploying the stack,
# or create a .env file alongside docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL must be running externally, accessible from the container)
# -----------------------------------------------------------------------------
POSTGRES_HOST=db.example.com
POSTGRES_PORT=5432
POSTGRES_DB=weightloss
POSTGRES_USER=weightloss
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# App secrets - CHANGE THESE
# -----------------------------------------------------------------------------
SESSION_SECRET=change-me-to-a-very-long-random-string-at-least-64-chars
SESSION_TTL_HOURS=720

# -----------------------------------------------------------------------------
# Seed admin account (created on first boot when no users exist)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-now-please
SEED_ADMIN_NAME=Admin

# -----------------------------------------------------------------------------
# Registration mode (true = invite-only, false = open registration)
# -----------------------------------------------------------------------------
INVITE_ONLY=true

# -----------------------------------------------------------------------------
# Upload limits
# -----------------------------------------------------------------------------
MAX_PHOTO_SIZE_MB=10
MAX_PHOTO_STORAGE_MB=500
MAX_PHOTOS_PER_DAY=50

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
LOGIN_RATE_LIMIT_PER_HOUR=10

# -----------------------------------------------------------------------------
# Public URL (used for external links; change if behind a reverse proxy)
# -----------------------------------------------------------------------------
PUBLIC_URL=http://your-nas-ip:7673

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Europe/Amsterdam
