# =============================================================================
# Weight Loss Web App - environment variables
# Copy this file to /volume1/Docker/weightloss-app/env/.env and edit values.
# This file is bind-mounted into the app container as /app/.env.production
# and also used by the backup container via docker-compose.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_DB=weightloss
POSTGRES_USER=weightloss
# CHANGE THIS. Use a long random string. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# -----------------------------------------------------------------------------
# Host user / group IDs (matches the NAS user owning the bind-mounted folders)
# On ASUSTOR ADM, PUID/PGID for the default admin are usually 1000:1000.
# Run `id` over SSH as the user that owns /volume1/Docker to confirm.
# -----------------------------------------------------------------------------
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# App secrets
# -----------------------------------------------------------------------------
# CHANGE THIS. Long random string. Generate with: openssl rand -hex 64
SESSION_SECRET=change-me-to-a-very-long-random-string-at-least-64-chars

# Session lifetime in hours (default 720 = 30 days)
SESSION_TTL_HOURS=720

# -----------------------------------------------------------------------------
# Seed admin account (only used on first startup, when the users table is empty)
# CHANGE THE PASSWORD IMMEDIATELY AFTER FIRST LOGIN.
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-now-please
SEED_ADMIN_NAME=Admin

# -----------------------------------------------------------------------------
# Registration mode
# true  = invite-only (admin must create invites)
# false = anyone with the URL can register
# -----------------------------------------------------------------------------
INVITE_ONLY=true

# -----------------------------------------------------------------------------
# Upload limits (per requirements)
# -----------------------------------------------------------------------------
MAX_PHOTO_SIZE_MB=10
MAX_PHOTO_STORAGE_MB=500
MAX_PHOTOS_PER_DAY=50

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
LOGIN_RATE_LIMIT_PER_HOUR=10

# -----------------------------------------------------------------------------
# Public URL (used in any external links; safe to leave default for local use)
# -----------------------------------------------------------------------------
PUBLIC_URL=http://localhost:3886

# -----------------------------------------------------------------------------
# Backup sidecar
# -----------------------------------------------------------------------------
BACKUP_KEEP_DAYS=14
# Daily at 03:00 in the TZ below. Format: standard crontab (min hour dom mon dow)
BACKUP_CRON=0 3 * * *
TZ=Europe/Amsterdam

# -----------------------------------------------------------------------------
# Port exposed on the NAS host that maps to the app's container port 3000
# -----------------------------------------------------------------------------
APP_PORT=3886
